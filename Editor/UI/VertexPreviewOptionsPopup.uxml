<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="True">
    <ui:VisualElement name="popup-root" class="dennoko-card" style="margin-top: 8px;">
        <ui:Label name="title-label" text="Vertex Preview Settings" class="dennoko-section-title dennoko-card-header" />
        <uie:ColorField name="normal-color-field" label="Normal Color" show-alpha="false" />
        <uie:ColorField name="selected-color-field" label="Selected Color" show-alpha="false" />
        <ui:Slider name="size-slider" label="Size" low-value="0.1" high-value="5" show-input-field="true" />
    </ui:VisualElement>
</ui:UXML>
